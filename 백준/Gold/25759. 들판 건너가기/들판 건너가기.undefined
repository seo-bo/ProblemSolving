#include<bits/stdc++.h>
using namespace std;
typedef long long ll;

int main(void)
{
	cin.tie(0)->sync_with_stdio(0);
	int n = 0;
	cin >> n;
	vector<ll>dp(101, -1);
	int p = 0;
	cin >> p;
	dp[p] = 0;
	for (int i = 1; i < n; ++i)
	{
		int a = 0;
		cin >> a;
		vector<ll>temp = dp;
		for (int j = 1; j <= 100; ++j)
		{
			if (dp[j] == -1)
			{
				continue;
			}
			temp[a] = max(temp[a], dp[j] + (a - j) * (a - j));
		}
		dp = move(temp);
	}
	ll ans = 0;
	for (int i = 1; i <= 100; ++i)
	{
		ans = max(ans, dp[i]);
	}
	cout << ans;
	return 0;
}